# ===========================================
# AI Gateway Configuration
# ===========================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ===========================================

# --- Auth ---
# API key for Bearer token authentication
# Generate something strong: openssl rand -hex 32
API_KEY=change-me

# --- Model ---
# GGUF model filename (must exist in ./models/)
MODEL_FILE=qwen2.5-7b-instruct-q4_k_m.gguf

# OpenAI-style model alias (what clients send as "model")
MODEL_ALIAS=qwen2.5

# --- Tailscale ---
# Reusable auth key from: https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=tskey-auth-xxxxx

# Hostname on your tailnet (your URL will be https://<hostname>.<tailnet>.ts.net)
TS_HOSTNAME=ai-gateway

# --- llama.cpp ---
# Number of CPU threads for inference
LLAMA_THREADS=4

# Context window size (tokens)
LLAMA_CTX_SIZE=4096

# GPU layers to offload (0 = CPU only, 999 = all layers on GPU)
LLAMA_GPU_LAYERS=0
